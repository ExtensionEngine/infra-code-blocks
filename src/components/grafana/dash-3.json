      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "afjuh8qb6xvk0c"
                    },
                    "group": "cloudwatch",
                    "kind": "DataQuery",
                    "spec": {
                      "expression": "fields @Timestamp, trace_id as traceId, trace_id as traceIdTab\n          | parse @message '\"body\":\"*\"' as body\n          | parse @message '\"res\":{\"statusCode\":*}' as statusCode\n          | parse @message '\"severity_text\":\"*\"' as logLevel\n          | parse @message '\"url\":\"*\"' as httpUrl\n          | parse @message '\"method\":\"*\"' as httpMethod\n          | filter body like /${search_text}/\n          | filter ${status_code}\n          | filter ${log_level}\n          | sort @timestamp desc\n          | limit ${limit}",
                      "logGroups": [
                        {
                          "name": "icb-test-dev-lg"
                        }
                      ],
                      "queryMode": "Logs",
                      "region": "default"
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": [
              {
                "group": "organize",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "excludeByName": {
                      "Value": true
                    },
                    "indexByName": {
                      "@timestamp": 0,
                      "body": 3,
                      "logLevel": 2,
                      "statusCode": 1
                    },
                    "renameByName": {
                      "@timestamp": "Timestamp",
                      "body": "Body",
                      "httpMethod": "HTTP Method",
                      "httpUrl": "HTTP URL",
                      "logLevel": "Log Level",
                      "statusCode": "Status Code",
                      "traceId": "Trace Id",
                      "traceIdTab": "Trace Id Tab"
                    }
                  }
                }
              },
              {
                "group": "sortBy",
                "kind": "Transformation",
                "spec": {
                  "options": {
                    "sort": [
                      {
                        "desc": true,
                        "field": "Time"
                      }
                    ]
                  }
                }
              }
            ]
          }
        },
        "description": "",
        "id": 1,
        "links": [],
        "title": "Logs",
        "vizConfig": {
          "group": "table",
          "kind": "VizConfig",
          "spec": {
